{
  "name": "import-integrity-lint",
  "version": "1.2.0",
  "description": "High-performance ESLint/Oxlint plugin that catches dead code, broken imports, and architectural violations. Optimized for monorepos.",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "eslintplugin",
    "oxlint",
    "oxlint-plugin",
    "import",
    "imports",
    "exports",
    "unused-exports",
    "dead-code",
    "cycle",
    "circular-dependencies",
    "boundaries",
    "monorepo",
    "typescript",
    "nextjs",
    "import-integrity",
    "fast-import"
  ],
  "homepage": "https://nebrius.github.io/import-integrity-lint/",
  "bugs": "https://github.com/nebrius/import-integrity-lint/issues",
  "license": "MIT",
  "author": "Bryan Hughes <bryan@nebri.us>",
  "repository": {
    "type": "git",
    "url": "https://github.com/nebrius/import-integrity-lint.git"
  },
  "type": "module",
  "main": "dist/plugin.js",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    }
  },
  "scripts": {
    "lint": "npm run lint:eslint && npm run lint:oxlint",
    "lint:eslint": "TIMING=1 eslint --report-unused-disable-directives \"**/*.{ts,tsx,mts,js,jsx,mjs}\"",
    "lint:eslint:fix": "eslint --fix \"**/*.{js,jsx,mjs,ts,tsx,mts}\"",
    "lint:oxlint": "oxlint --type-aware",
    "build": "tsc",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage src",
    "format": "prettier --write A\"**/*.{js,jsx,mjs,ts,tsx,mts}\""
  },
  "dependencies": {
    "@manypkg/get-packages": "3.1.0",
    "@typescript-eslint/typescript-estree": "^8.29.1",
    "@typescript-eslint/utils": "^8.19.1",
    "ignore": "^7.0.3",
    "jsonc-parser": "3.3.1",
    "oxc-parser": "^0.106.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^9.24.0",
    "@jest/globals": "^30.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.0",
    "@typescript-eslint/rule-tester": "^8.29.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "fast-deep-equal": "^3.1.3",
    "globals": "^17.0.0",
    "jest-diff": "^30.0.0",
    "mermaid": "11.14.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.23.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.2.5",
    "ts-jest-resolver": "^2.0.1",
    "type-fest": "^5.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.29.1",
    "vitepress": "1.6.4",
    "vitepress-plugin-llms": "1.12.2",
    "vitepress-plugin-mermaid": "2.0.17"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  }
}
